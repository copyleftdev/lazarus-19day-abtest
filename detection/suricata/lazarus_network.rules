# === Wave 1: OpenClaw Wallet Drainer C2 ===

alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"LAZARUS OpenClaw C2 - watery-compost.today";
    flow:to_server,established;
    content:"watery-compost.today"; http_host;
    classtype:trojan-activity;
    sid:2026040801; rev:1;
    metadata:attack_target Client_Endpoint, created_at 2026_04_08, deployment Perimeter, tag Lazarus_OpenClaw;
)

alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"LAZARUS OpenClaw Phishing - token-claw.xyz";
    flow:to_server,established;
    content:"token-claw.xyz"; http_host;
    classtype:social-engineering;
    sid:2026040802; rev:1;
)

